    |   CONST_NUMBER(0) TYPE=i32

fn inc(num: *i32) -> unit
    BLOCK TYPE=unit
    |   DECLARE var_2 : *i32
    |   STORE TYPE=unit
    |   |   VARIABLE(var_2) [LVALUE] TYPE=*i32
    |   |   ARGUMENT("num") TYPE=*i32
    |   BLOCK TYPE=unit
    |   |   DECLARE var_3 : *i32
    |   |   STORE TYPE=unit
    |   |   |   VARIABLE(var_3) [LVALUE] TYPE=*i32
    |   |   |   GET_POINTER TYPE=*i32
    |   |   |   |   DEREFERENCE [LVALUE] TYPE=i32
    |   |   |   |   |   VARIABLE(var_2) [LVALUE] TYPE=*i32
    |   |   STORE TYPE=unit
    |   |   |   DEREFERENCE [LVALUE] TYPE=i32
    |   |   |   |   VARIABLE(var_3) [LVALUE] TYPE=*i32
    |   |   |   ARITHMETIC(Add) TYPE=i32
    |   |   |   |   DEREFERENCE [LVALUE] TYPE=i32
